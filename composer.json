{
	"name": "konradmichalik/typo3-ai-mate",
	"description": "Dev-only TYPO3 extension and symfony/ai-mate bridge that exposes the resolved runtime state of a TYPO3 installation (TCA, pages, TypoScript, middlewares, logs, request profiles) to AI coding assistants via MCP tools.",
	"license": [
		"GPL-2.0-or-later"
	],
	"type": "typo3-cms-extension",
	"authors": [
		{
			"name": "Konrad Michalik",
			"email": "km@move-elevator.de",
			"role": "Maintainer"
		}
	],
	"require": {
		"php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
		"ext-mbstring": "*",
		"helgesverre/toon": "^3.1",
		"konradmichalik/typo3-request-profiler": "^0.2",
		"mcp/sdk": "^0.5",
		"nikic/php-parser": "^5.0",
		"psr/http-server-handler": "^1.0",
		"psr/http-server-middleware": "^1.0",
		"psr/log": "^3.0",
		"symfony/ai-mate": "^0.9",
		"symfony/console": "^6.4 || ^7.0",
		"symfony/dependency-injection": "^6.4 || ^7.0",
		"symfony/finder": "^6.4 || ^7.0",
		"symfony/process": "^6.4 || ^7.0",
		"typo3/cms-core": "^13.4 || ^14.3",
		"typo3/cms-install": "^13.4 || ^14.3"
	},
	"require-dev": {
		"composer/class-map-generator": "^1.0",
		"phpunit/phpcov": "^9.0 || ^10.0 || ^11.0 || ^13.0",
		"phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
		"psr/http-message": "^1.0 || ^2.0",
		"typo3/cms-base-distribution": "^13.4 || ^14.3",
		"typo3/testing-framework": "^9.5"
	},
	"autoload": {
		"psr-4": {
			"KonradMichalik\\Typo3AiMate\\": "Classes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"KonradMichalik\\Typo3AiMate\\Tests\\": "Tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"php-http/discovery": true,
			"symfony/ai-mate-composer-plugin": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"platform": {
			"php": "8.2"
		},
		"sort-packages": true
	},
	"extra": {
		"ai-mate": {
			"includes": [
				"Configuration/Mate.php"
			],
			"instructions": "INSTRUCTIONS.md",
			"scan-dirs": [
				"Classes/Mcp"
			]
		},
		"konradmichalik/php-cs-fixer-preset": {
			"copyright": 2026
		},
		"typo3/cms": {
			"Package": {
				"providesPackages": {}
			},
			"cms-package-dir": "{$vendor-dir}/typo3/cms",
			"extension-key": "typo3_ai_mate",
			"version": "0.1.0",
			"web-dir": "public"
		}
	},
	"scripts": {
		"post-install-cmd": [
			"@cgl install"
		],
		"cgl": "@composer -d Tests/CGL --",
		"test": [
			"@test:unit",
			"@test:functional"
		],
		"test:coverage": [
			"@php -dpcov.enabled=1 vendor/bin/phpunit -c phpunit.xml --coverage-php=.Build/coverage/cov/unit.cov",
			"@php -dpcov.enabled=1 vendor/bin/phpunit -c FunctionalTests.xml --coverage-php=.Build/coverage/cov/functional.cov",
			"@php vendor/bin/phpcov merge --clover=.Build/coverage/clover.xml --html=.Build/coverage/html --text=php://stdout .Build/coverage/cov"
		],
		"test:coverage:unit": "@php -dpcov.enabled=1 vendor/bin/phpunit -c phpunit.xml",
		"test:functional": "phpunit -c FunctionalTests.xml",
		"test:unit": "phpunit -c phpunit.xml --no-coverage"
	}
}
