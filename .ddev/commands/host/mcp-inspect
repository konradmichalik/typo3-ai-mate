#!/usr/bin/env bash

## Description: Inspect the typo3-ai-mate MCP server with the MCP Inspector
## Usage: mcp-inspect [13|14] [inspector args...]
## Example: "ddev mcp-inspect 13" (interactive UI), "ddev mcp-inspect 14 --cli --method tools/list"

set -euo pipefail

VERSION="${1:-13}"
if [ "$#" -gt 0 ]; then shift; fi

INSTANCE="/var/www/html/.Build/${VERSION}"

# The Inspector runs here on the host (Node/npx); the MCP server itself
# (vendor/bin/mate serve, stdio transport) runs inside the web container.
#
# We hand the server to the Inspector via a generated config file with `args` as
# a JSON array. The interactive UI splits a plain command field on spaces, which
# would shred the `bash -c "..."` argument and make "Connect" fail — a config
# file keeps it as a single argument. We deliberately use `ddev exec` rather than
# the `ddev <version>` wrapper, whose "[TYPO3 v<n>] ..." header would corrupt the
# stdio MCP stream.
CONFIG="$(mktemp -t mcp-inspect.XXXXXX)"
trap 'rm -f "${CONFIG}"' EXIT

cat > "${CONFIG}" <<JSON
{
  "mcpServers": {
    "typo3-ai-mate": {
      "command": "ddev",
      "args": ["exec", "bash", "-c", "cd ${INSTANCE} && exec ./vendor/bin/mate serve"]
    }
  }
}
JSON

# Without extra args the interactive browser UI opens, pre-wired to the server —
# just click "Connect", then open the Tools tab. Pass Inspector CLI flags for
# headless checks, e.g.:
#   ddev mcp-inspect 13 --cli --method tools/list
#   ddev mcp-inspect 13 --cli --method tools/call --tool-name typo3-tca --tool-arg table=tt_content
npx --yes @modelcontextprotocol/inspector@latest --config "${CONFIG}" --server typo3-ai-mate "$@"
