# MCP client config written by `mate init` / the ai-mate composer plugin —
# machine-/setup-specific (stdio command differs host vs. ddev), never committed.
/.ai/
/mcp.json
/.mcp.json
/.Build/
/public/
/var/
/vendor/
.DS_Store
.phpunit.result.cache

# DDEV: only config.yaml and our own custom commands are tracked; the
# multi-version add-on and ddev-generated files are fetched via
# `ddev add-on get konradmichalik/ddev-typo3-multi-version-extension`.
/.ddev/*
!/.ddev/config.yaml
!/.ddev/commands
/.ddev/commands/*
!/.ddev/commands/host
/.ddev/commands/host/*
!/.ddev/commands/host/mcp-inspect
!/.ddev/commands/host/mcp-smoke
!/.ddev/commands/host/mate-setup

# php-cs-fixer cache (created when running CGL config from repo root)
.php-cs-fixer.cache
